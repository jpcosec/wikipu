@startuml
skinparam component<<boundary>> BackgroundColor #FCECC9
skinparam component<<boundary>> BorderColor #D4A73C
skinparam component<<boundary>> FontColor #5E450B
skinparam rectangle<<boundary>> BackgroundColor #FCECC9
skinparam rectangle<<boundary>> BorderColor #D4A73C
skinparam rectangle<<boundary>> FontColor #5E450B
skinparam database<<boundary>> BackgroundColor #FCECC9
skinparam database<<boundary>> BorderColor #D4A73C
skinparam database<<boundary>> FontColor #5E450B
skinparam package<<boundary>> BackgroundColor #FCECC9
skinparam package<<boundary>> BorderColor #D4A73C
skinparam package<<boundary>> FontColor #5E450B
skinparam component<<core>> BackgroundColor #D8ECFF
skinparam component<<core>> BorderColor #4C78A8
skinparam component<<core>> FontColor #16324F
skinparam rectangle<<core>> BackgroundColor #D8ECFF
skinparam rectangle<<core>> BorderColor #4C78A8
skinparam rectangle<<core>> FontColor #16324F
skinparam database<<core>> BackgroundColor #D8ECFF
skinparam database<<core>> BorderColor #4C78A8
skinparam database<<core>> FontColor #16324F
skinparam package<<core>> BackgroundColor #D8ECFF
skinparam package<<core>> BorderColor #4C78A8
skinparam package<<core>> FontColor #16324F
skinparam component<<database>> BackgroundColor #DCEFD8
skinparam component<<database>> BorderColor #5A9B5A
skinparam component<<database>> FontColor #1F4F1F
skinparam rectangle<<database>> BackgroundColor #DCEFD8
skinparam rectangle<<database>> BorderColor #5A9B5A
skinparam rectangle<<database>> FontColor #1F4F1F
skinparam database<<database>> BackgroundColor #DCEFD8
skinparam database<<database>> BorderColor #5A9B5A
skinparam database<<database>> FontColor #1F4F1F
skinparam package<<database>> BackgroundColor #DCEFD8
skinparam package<<database>> BorderColor #5A9B5A
skinparam package<<database>> FontColor #1F4F1F

package "Workspace Zones" as WorkspaceZones <<boundary>> {
  [RawZone]
  [WikiZone]
  [DeskZone]
  [DrawersZone]
  [SrcZone]
  [TestsZone]
}
rectangle "raw/" as RawZone <<boundary>>
rectangle "wiki/" as WikiZone <<boundary>>
rectangle "desk/" as DeskZone <<boundary>>
rectangle "drawers/" as DrawersZone <<boundary>>
rectangle "src/" as SrcZone <<boundary>>
rectangle "tests/" as TestsZone <<boundary>>
package "wiki-compiler CLI" as WikiCompilerCLI <<core>> {
  [Commands]
}
package "commands/" as Commands <<core>> {
  [BuildPipeline]
  [QueryLayer]
  [ContextLayer]
  [EnergyLayer]
  [CleanseLayer]
  [RunLoop]
}
package "Build Pipeline" as BuildPipeline <<core>> {
  [Builder]
  [Scanner]
  [Templates]
  [Injectors]
  [Perception]
}
component "builder.py" as Builder <<core>>
component "scanner.py" as Scanner <<core>>
component "node_templates.py" as Templates <<core>>
component "facet_injectors.py" as Injectors <<core>>
component "perception.py" as Perception <<core>>
package "Knowledge Graph Core" as GraphCore <<core>> {
  [Contracts]
  [GraphUtils]
  [QueryExecutor]
  [QueryLanguage]
  [ContextCore]
  [EnergyCore]
  [Cleanser]
  [OwlReasoner]
  [Registry]
}
component "contracts.py" as Contracts <<core>>
component "graph_utils.py" as GraphUtils <<core>>
component "query_executor.py" as QueryExecutor <<core>>
component "query_language.py" as QueryLanguage <<core>>
component "context.py" as ContextCore <<core>>
component "energy.py" as EnergyCore <<core>>
component "cleanser.py" as Cleanser <<core>>
component "owl_reasoner.py" as OwlReasoner <<core>>
component "registry.py + facet_validator.py" as Registry <<core>>
component "Query" as QueryLayer <<core>>
component "Context" as ContextLayer <<core>>
component "Energy" as EnergyLayer <<core>>
component "Cleanse" as CleanseLayer <<core>>
component "Coordinator Run Loop" as RunLoop <<core>>
database "knowledge_graph.json" as GraphArtifact <<database>>
package "Outputs" as Outputs <<boundary>> {
  [StatusAudit]
  [ContextBundle]
  [EnergyReport]
}
rectangle "status + audit" as StatusAudit <<boundary>>
rectangle "context bundles" as ContextBundle <<boundary>>
rectangle "energy reports" as EnergyReport <<boundary>>

WorkspaceZones --> WikiCompilerCLI : inputs
WikiCompilerCLI --> Commands : dispatch
Commands --> BuildPipeline : build
Commands --> QueryLayer : query
Commands --> ContextLayer : context
Commands --> EnergyLayer : energy
Commands --> CleanseLayer : cleanse
Commands --> RunLoop : run
BuildPipeline --> GraphCore : compile nodes
BuildPipeline --> GraphArtifact : save graph
QueryLayer --> GraphCore : traversal
ContextLayer --> GraphCore : routing
EnergyLayer --> GraphCore : audit
CleanseLayer --> GraphCore : optimization
RunLoop --> GraphArtifact : compiled state
GraphCore --> GraphArtifact : node-link JSON
GraphArtifact --> Outputs : query and reports
QueryLayer --> StatusAudit : graph lookup
ContextLayer --> ContextBundle : LLM context
EnergyLayer --> EnergyReport : health report
@enduml
skinparam component<<database>> FontColor #1F4F1F
skinparam rectangle<<database>> BackgroundColor #DCEFD8
skinparam rectangle<<database>> BorderColor #5A9B5A
skinparam rectangle<<database>> FontColor #1F4F1F
skinparam database<<database>> BackgroundColor #DCEFD8
skinparam database<<database>> BorderColor #5A9B5A
skinparam database<<database>> FontColor #1F4F1F
skinparam package<<database>> BackgroundColor #DCEFD8
skinparam package<<database>> BorderColor #5A9B5A
skinparam package<<database>> FontColor #1F4F1F

package "wikipu" as Wikipu <<core>> {
  component "wiki-compiler CLI" as CuratorCLI <<core>>
  rectangle "wiki/ + desk/ + drawers/ + raw/ + src/" as WorkspaceZones <<boundary>>
  component "curation and orchestration" as CurationFlows <<core>>
}
package "sldb" as SLDB <<core>> {
  database "documents" as DocumentStore <<database>>
  component "models + templates" as ModelsTemplates <<core>>
  component "validation + document index" as ValidationIndex <<core>>
}
package "kgdb" as KGDB <<core>> {
  database "horizontal relations" as RelationGraph <<database>>
  component "semantic overlays" as SemanticLayer <<core>>
  component "reasoning + query + reports" as ReasoningQuery <<core>>
}
package "stable interfaces" as Interfaces <<boundary>> {
  rectangle "sldb exports" as SLDBExport <<boundary>>
  rectangle "kgdb exports" as KGDBViews <<boundary>>
}
package "operator outputs" as Outputs <<boundary>> {
  rectangle "curated wiki view" as WikiProjection <<boundary>>
  rectangle "audit + context + energy" as AuditContext <<boundary>>
  rectangle "gates + tasks + proposals" as FutureActions <<boundary>>
}

Wikipu --> SLDB : documents and index
Wikipu --> KGDB : relations and semantics
SLDB --> Interfaces : indexed facts
KGDB --> Interfaces : graph and semantic views
Interfaces --> Outputs : curated presentation
@enduml
skinparam database<<boundary>> BorderColor #D4A73C
skinparam database<<boundary>> FontColor #5E450B
skinparam package<<boundary>> BackgroundColor #FCECC9
skinparam package<<boundary>> BorderColor #D4A73C
skinparam package<<boundary>> FontColor #5E450B
